# ============================================================================
# Mr. Snowman Backend Environment Configuration
# ============================================================================

# Server Configuration
NODE_ENV=development
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Backend URL (for tracking pixels and click tracking links)
# This must be the publicly accessible URL of your backend server
BACKEND_URL=http://localhost:3001

# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Encryption Key (for encrypting email passwords)
# Generate a 32-byte hex key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-key-here

# ============================================================================
# OAuth Configuration (for multi-provider email sending)
# ============================================================================

# Gmail OAuth Credentials
# Setup guide: See backend/GMAIL_OAUTH_SETUP.md
# Get these from: https://console.cloud.google.com/
GMAIL_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=your-google-client-secret
GMAIL_OAUTH_REDIRECT_URI=https://your-backend-url.onrender.com/api/oauth/gmail/callback

# Microsoft OAuth Credentials
# Setup guide: See backend/MICROSOFT_OAUTH_SETUP.md
# Get these from: https://portal.azure.com/
MICROSOFT_OAUTH_CLIENT_ID=your-azure-application-client-id
MICROSOFT_OAUTH_CLIENT_SECRET=your-azure-client-secret
MICROSOFT_OAUTH_REDIRECT_URI=https://your-backend-url.onrender.com/api/oauth/microsoft/callback

# ============================================================================
# Optional Configuration
# ============================================================================

# Optional: Logging
LOG_LEVEL=info

# Optional: Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
