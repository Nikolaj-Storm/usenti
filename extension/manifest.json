{
    "manifest_version": 3,
    "name": "Usenti LinkedIn Outreach",
    "version": "1.1.0",
    "description": "Automate LinkedIn outreach — DMs and connection requests — as part of your Usenti multichannel campaigns.",
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.linkedin.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end"
        }
    ],
    "host_permissions": [
        "*://*.linkedin.com/*",
        "http://localhost:3000/*",
        "https://*.onrender.com/*",
        "https://nikolaj-storm.github.io/*",
        "https://*.usenti.com/*",
        "https://usenti.com/*"
    ],
    "permissions": [
        "storage",
        "alarms",
        "activeTab",
        "scripting",
        "cookies"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}